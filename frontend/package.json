{
  "name": "smartmoneymethod.au-frontend",
  "version": "1.0.0",
  "description": "Vite + React frontend with public and admin pages",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node -e \"if(!process.env.VERCEL){require('child_process').execSync('react-snap',{stdio:'inherit'})}else{console.log('Skipping react-snap on Vercel (run locally instead)')}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "react-snap": "^1.23.0",
    "vite": "^5.1.0"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "include": [
      "/",
      "/calculator",
      "/pay-calculator",
      "/budget",
      "/compounding-calculator",
      "/dca-calculator",
      "/charts",
      "/trading-grounds",
      "/backtesting",
      "/learn/trading-strategy",
      "/learn/investing-strategy",
      "/learn/blog"
    ],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "headless": true,
    "saveAs": "html",
    "inlineCss": false,
    "cacheAjaxRequests": false
  }
}
